  "keyFeatures": [
    "Rich type serialization (Set, Map, Date, RegExp, BigInt, circular references) via devalue",
    "TTL / key expiration with lazy cleanup on read",
    "Namespacing with configurable prefix and separator",
    "Schema validation on read using any Standard Schema-compatible library (Zod, Valibot, ArkType)",
    "Pluggable Storage backend (localStorage, sessionStorage, in-memory)",
    "Custom serializer support with a tree-shakeable greatstorage/core entry point",
    "Full TypeScript types with ESM and CJS dual builds"
  ],
  "publicApiSurface": [
    "createStorage(options?: CreateStorageOptions): GreatStorage",
    "createMemoryStorage(): Storage",
    "GreatStorage.getItem<T>(key, options?): T | null",
    "GreatStorage.setItem<T>(key, value, options?): void",
    "GreatStorage.getOrInit<T>(key, factory, options?): T",
    "GreatStorage.updateItem<T>(key, updater, options?): T",
    "GreatStorage.removeItem(key): void",
    "GreatStorage.has(key): boolean",
    "GreatStorage.key(index): string | null",
    "GreatStorage.clear(): void",
    "GreatStorage.clearExpired(): void",
    "GreatStorage.length: number",
    "greatstorage/core (createStorage without devalue bundled)"
  ]
}
